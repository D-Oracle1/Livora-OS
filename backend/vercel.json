{
  "version": 2,
  "framework": null,
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "npm run build",
  "crons": [
    {
      "path": "/api/v1/cron/keep-alive",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/v1/cron/rankings/daily",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/v1/cron/rankings/monthly",
      "schedule": "0 2 1 * *"
    },
    {
      "path": "/api/v1/cron/rankings/yearly",
      "schedule": "0 3 1 1 *"
    },
    {
      "path": "/api/v1/cron/overdue-payments",
      "schedule": "0 6 * * *"
    }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "memory": 1769,
      "includeFiles": "{dist/**,prisma/**,node_modules/.prisma/**,node_modules/@prisma/engines/**,node_modules/pg*/**,node_modules/{exceljs,archiver,@vercel/blob,undici,openai,@sentry,passport-google-oauth20,passport-facebook}/**}"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.ts"
    }
  ]
}
